# Copy this file to .env and fill in every value before running deploy.sh.
# .env is gitignored and must never be committed.

# ── Database ─────────────────────────────────────────────────────────────────
# Strong password for the PostgreSQL tickets user.
# Generate one: openssl rand -hex 24
POSTGRES_PASSWORD=changeme_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Secret used to sign auth tokens. Must be at least 32 characters.
# Generate one: openssl rand -hex 32
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin password for the Grafana UI.
GF_ADMIN_PASSWORD=changeme_grafana_admin

# ── Domain ────────────────────────────────────────────────────────────────────
# Your base domain. Used to set Grafana's root URL.
# Example: ckonkol.net  →  Grafana will expect https://grafana.ckonkol.net
DOMAIN=ckonkol.net
