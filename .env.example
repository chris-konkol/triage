# Copy this file to .env and fill in every value before running deploy.sh.
# .env is gitignored and must never be committed.

# ── Database ─────────────────────────────────────────────────────────────────
# Strong password for the PostgreSQL tickets user.
# Generate one: openssl rand -hex 24
POSTGRES_PASSWORD=changeme_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Secret used to sign auth tokens. Must be at least 32 characters.
# Generate one: openssl rand -hex 32
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# ── Registration ──────────────────────────────────────────────────────────────
# Token required in X-Registration-Token header to create new accounts.
# Without this, POST /api/auth/register returns 403.
# Generate one: openssl rand -hex 24
REGISTRATION_TOKEN=changeme_generate_with_openssl_rand_hex_24

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin password for the Grafana UI.
GF_ADMIN_PASSWORD=changeme_grafana_admin

# ── Domain ────────────────────────────────────────────────────────────────────
# Your base domain. Used to set Grafana's root URL.
# Example: ckonkol.net  →  Grafana will expect https://grafana.ckonkol.net
DOMAIN=ckonkol.net

# ── MCP server ────────────────────────────────────────────────────────────────
# Credentials for the MCP service to authenticate with the Triage API.
MCP_USERNAME=mcp
MCP_PASSWORD=changeme_mcp_password

# OAuth 2.1 settings for the MCP server's built-in authorization server.
# MCP_SERVER_URL: public base URL of the MCP service (no trailing slash).
MCP_SERVER_URL=https://mcp.ckonkol.net

# Client credentials — enter these in Claude's custom connector advanced settings.
# Generate: openssl rand -hex 32
OAUTH_CLIENT_ID=triage-claude
OAUTH_CLIENT_SECRET=changeme_generate_with_openssl_rand_hex_32

# JWT secret used to sign MCP access tokens. Keep separate from JWT_SECRET.
# Generate: openssl rand -hex 32
MCP_JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# Credentials for the OAuth login page (who can grant Claude access).
# This is independent of Triage app accounts.
TRIAGE_ADMIN_USER=chris
# Generate hash: htpasswd -nbBC 12 "" "yourpassword" | tr -d ':\n' | sed 's/^!//'
# Or with Python: python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt(12)).decode())"
TRIAGE_ADMIN_PASS_HASH=changeme_bcrypt_hash_of_your_password
